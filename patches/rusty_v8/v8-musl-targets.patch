Change GN target triples from gnu to musl for Alpine Linux builds.

--- a/build/config/compiler/BUILD.gn	2026-03-20 16:45:38.513017173 -0400
+++ b/build/config/compiler/BUILD.gn	2026-03-20 16:49:03.135391942 -0400
@@ -1300,8 +1300,8 @@
     # simplicity we always explicitly set the architecture.
     if (current_cpu == "x64") {
       if (is_clang && !is_android && !is_fuchsia && !is_chromeos_device) {
-        cflags += [ "--target=x86_64-unknown-linux-gnu" ]
-        ldflags += [ "--target=x86_64-unknown-linux-gnu" ]
+        cflags += [ "--target=x86_64-alpine-linux-musl" ]
+        ldflags += [ "--target=x86_64-alpine-linux-musl" ]
       } else {
         cflags += [ "-m64" ]
         ldflags += [ "-m64" ]
@@ -1335,8 +1335,8 @@
       ]
     } else if (current_cpu == "arm64") {
       if (is_clang && !is_android && !is_fuchsia && !is_chromeos_device) {
