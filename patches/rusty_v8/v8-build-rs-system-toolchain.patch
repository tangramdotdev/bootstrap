Patch build.rs for system toolchain support:
- Skip downloading Chromium Rust toolchain when system Rust is pre-configured
- Skip sysroot installation when CLANG_BASE_PATH is set (system toolchain)
- Use system C++ headers for bindgen when not using custom libc++
- Trust CLANG_BASE_PATH without version check

--- a/build.rs	2026-03-20 16:53:13.114514827 -0400
+++ b/build.rs	2026-03-20 16:57:10.974293793 -0400
@@ -183,13 +183,19 @@
     "-x".to_string(),
     "c++".to_string(),
     "-std=c++20".to_string(),
-    "-nostdinc++".to_string(),
+  ];
+  if env::var("CLANG_BASE_PATH").is_err() {
+    clang_args.extend_from_slice(&[
+      "-nostdinc++".to_string(),
+      "-isystembuildtools/third_party/libc++".to_string(),
+      "-isystemthird_party/libc++/src/include".to_string(),
+      "-isystemthird_party/libc++abi/src/include".to_string(),
+    ]);
+  }
+  clang_args.extend_from_slice(&[
     "-Iv8/include".to_string(),
     "-I.".to_string(),
-    "-isystembuildtools/third_party/libc++".to_string(),
-    "-isystemthird_party/libc++/src/include".to_string(),
-    "-isystemthird_party/libc++abi/src/include".to_string(),
-  ];
+  ]);
 
   let target_os = env::var("CARGO_CFG_TARGET_OS").unwrap();
   if target_os == "macos" {
@@ -357,7 +363,7 @@
